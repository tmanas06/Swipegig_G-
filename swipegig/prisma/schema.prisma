generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────

enum UserRole {
  SEEKER
  RECRUITER
  ADMIN
}

enum ApplicationStatus {
  APPLIED
  INTERVIEWING
  OFFERED
  REJECTED
  WITHDRAWN
}

enum RewardTrigger {
  PROFILE_COMPLETION
  FIRST_APPLICATION
  APPLICATION
  INTERVIEW_LANDED
  REFERRAL
  COMPANY_REVIEW
  DAILY_LOGIN
  ACHIEVEMENT
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  FREELANCE
  INTERNSHIP
}

enum JobMode {
  REMOTE
  HYBRID
  ONSITE
}

enum JobSource {
  REMOTIVE
  WELLFOUND
  GREENHOUSE
  WEB3_CAREER
  RECRUITER_POST
  MANUAL
}

enum ProfileVisibility {
  PUBLIC
  RECRUITERS_ONLY
  PRIVATE
}

// ─── User ───────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  privyId       String    @unique
  walletAddress String?   @unique
  ensName       String?
  email         String?   @unique
  name          String?
  avatarUrl     String?
  profileScore  Int       @default(0)
  isVerified    Boolean   @default(false)
  role          UserRole  @default(SEEKER)
  loginStreak   Int       @default(0)
  lastLoginAt   DateTime?
  onboardedOnChain Boolean  @default(false)
  
  // GoodDollar Proof of Humanity
  isGoodDollarVerified    Boolean   @default(false)
  goodDollarVerifiedAt    DateTime?
  goodDollarAddress       String?   @unique // wallet address that was verified
  lastAuthenticatedAt     DateTime? // from contract's lastAuthenticated()
  verificationExpiredAt   DateTime? // computed: lastAuthenticatedAt + authPeriod days
  
  // AI Coach prompt limiting
  aiPromptsUsed           Int       @default(0)
  aiPromptsLimit          Int       @default(5)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile       Profile?
  resume        Resume?
  savedJobs     SavedJob[]
  applications  Application[]
  rewards       Reward[]
  reviews       Review[]
  recruiter     Recruiter?
  verificationLogs VerificationCheckLog[]
  posts                 Post[]
  pollVotes             PollVote[]
  postTips              PostTip[]
  postSaves             PostSave[]
  weeklyCreatorBonuses  WeeklyCreatorBonus[]

  @@index([walletAddress])
  @@index([privyId])
}

// ─── Profile ────────────────────────────────────────────

model Profile {
  id            String            @id @default(cuid())
  userId        String            @unique
  bio           String?           @db.Text
  headline      String?
  skills        String[]
  githubUrl     String?
  linkedinUrl   String?
  portfolioUrl  String?
  location      String?
  ipfsHash      String?
  visibility    ProfileVisibility @default(PUBLIC)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Resume ─────────────────────────────────────────────

model Resume {
  id               String   @id @default(cuid())
  userId           String   @unique
  fileUrl          String
  fileName         String
  fileType         String
  parsedText       String?  @db.Text
  parsedSkills     String[]
  parsedExperience Json?
  parsedEducation  Json?
  parsedSummary    String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Job ────────────────────────────────────────────────

model Job {
  id             String    @id @default(cuid())
  externalId     String?   @unique
  title          String
  company        String
  companyLogo    String?
  description    String    @db.Text
  skills         String[]
  salaryMin      Int?
  salaryMax      Int?
  salaryCurrency String?   @default("USD")
  location       String?
  type           JobType   @default(FULL_TIME)
  mode           JobMode   @default(REMOTE)
  source         JobSource @default(MANUAL)
  sourceUrl      String?
  isWeb3         Boolean   @default(false)
  experienceLevel String?
  expiresAt      DateTime?
  postedAt       DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  savedBy        SavedJob[]
  applications   Application[]

  @@index([source])
  @@index([isWeb3])
  @@index([type, mode])
  @@index([createdAt])
}

// ─── SavedJob ───────────────────────────────────────────

model SavedJob {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  savedAt   DateTime @default(now())
  remindAt  DateTime?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
}

// ─── Application ────────────────────────────────────────

model Application {
  id             String            @id @default(cuid())
  userId         String
  jobId          String
  status         ApplicationStatus @default(APPLIED)
  coverLetter    String?           @db.Text
  resumeVersion  String?
  txHash         String?
  notes          String?           @db.Text
  appliedAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  job            Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
  @@index([status])
}

// ─── Reward ─────────────────────────────────────────────

model Reward {
  id        String        @id @default(cuid())
  userId    String
  amount    Float
  trigger   RewardTrigger
  txHash    String?
  metadata  Json?
  createdAt DateTime      @default(now())

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([trigger])
}

// ─── Review ─────────────────────────────────────────────

model Review {
  id          String   @id @default(cuid())
  userId      String
  companyName String
  rating      Int
  title       String?
  content     String   @db.Text
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyName])
}

// ─── Recruiter ──────────────────────────────────────────

model Recruiter {
  id            String   @id @default(cuid())
  userId        String   @unique
  companyName   String
  companyLogo   String?
  companyUrl    String?
  description   String?  @db.Text
  verified      Boolean  @default(false)
  stakeAmount   Float    @default(0)
  reputationScore Float  @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([verified])
}

// ─── Verification Check Log ──────────────────────────────

model VerificationCheckLog {
  id        String   @id @default(cuid())
  userId    String
  checkedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, checkedAt])
}

// ─── Creator Marketplace Models ──────────────────────────

model Post {
  id          String      @id @default(cuid())
  authorId    String
  author      User        @relation(fields: [authorId], references: [id])
  title       String
  type        PostType
  content     String?     // rich text / code content
  mediaUrl    String?     // IPFS url for images, Livepeer playbackId for video
  tags        String[]
  viewCount   Int         @default(0)
  tipTotal    Float       @default(0) // total G$ received
  saveCount   Int         @default(0)
  isPublished Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  pollOptions PollOption[]
  votes       PollVote[]
  tips        PostTip[]
  saves       PostSave[]
}

enum PostType {
  article
  image
  code
  poll
  video
}

model PollOption {
  id        String     @id @default(cuid())
  postId    String
  post      Post       @relation(fields: [postId], references: [id])
  text      String
  votes     PollVote[]
}

model PollVote {
  id        String     @id @default(cuid())
  postId    String
  post      Post       @relation(fields: [postId], references: [id])
  optionId  String
  option    PollOption @relation(fields: [optionId], references: [id])
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  createdAt DateTime   @default(now())
  @@unique([postId, userId]) // one vote per user per poll
}

model PostTip {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id])
  fromId    String
  from      User     @relation(fields: [fromId], references: [id])
  amount    Float    // G$ amount
  txHash    String   // on-chain tx hash
  createdAt DateTime @default(now())
}

model PostSave {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  @@unique([postId, userId])
}

model WeeklyCreatorBonus {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rank      Int      // 1, 2, or 3
  amount    Float    // 10, 5, or 1 G$
  weekOf    DateTime // Monday of that week
  txHash    String
  score     Int      // engagement score that week
  createdAt DateTime @default(now())
}
